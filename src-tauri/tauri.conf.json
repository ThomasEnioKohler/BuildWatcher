{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BuildWatcher",
  "version": "../package.json",
  "identifier": "ch.enio.buildwatcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BuildWatcher",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3MTQ2MkMwRTRGOEE5RTMKUldUanFmamt3R0lVVnpCUXZxRkdnQnUvVE5ZRGRVdnl4MlpZUUJSZlJ1TEo4eFdFOGtvU3d6eUEK",
      "endpoints": [
        "https://github.com/ThomasEnioKohler/BuildWatcher/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
